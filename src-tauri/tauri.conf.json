{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "schlag",
  "version": "1.0.4",
  "identifier": "com.carlo.schlag",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "schlag",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "dragDropEnabled": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxMUVDNEI0OTcxNUExODEKUldTQm9SV1h0TVFlY2VQY093a3FYWFQyeWwyU2lLZzFTTWV1VnlTdG9pdU9CMUxqeGhRblJsUUMK",
      "endpoints": [
        "https://github.com/MelAlejandrino/Schlag/releases/latest/download/latest.json"
      ]
    }
  }
}
